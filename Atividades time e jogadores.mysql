CREATE TABLE jogador (
    id INT AUTO_INCREMENT PRIMARY KEY,
    nome VARCHAR(100) NOT NULL,
    numero_camisa INT
);

DESCRIBE jogador;

ALTER TABLE jogador 
ADD COLUMN altura DECIMAL(3,2),
ADD COLUMN data_de_nascimento DATE;

DESCRIBE jogador;

DROP TABLE jogador;

SHOW TABLES;

CREATE TABLE jogador (
    id INT AUTO_INCREMENT PRIMARY KEY,
    nome VARCHAR(100) NOT NULL,
    numero_camisa INT,
    altura DECIMAL(3,2),
    data_de_nascimento DATE
);

