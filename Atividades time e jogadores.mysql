CREATE TABLE time (
    id INT AUTO_INCREMENT PRIMARY KEY,
    nome_time VARCHAR(100) NOT NULL,
    estado VARCHAR(2)
);

ALTER TABLE jogador ADD COLUMN id_time INT;

ALTER TABLE jogador 
ADD CONSTRAINT fk_jogador_time 
FOREIGN KEY (id_time) REFERENCES time(id);

ALTER TABLE jogador DROP INDEX numero_camisa;

-- Crie a regra: pode existir vários jogadores com o mesmo número mas que tenha que ser de times diferentes
ALTER TABLE jogador ADD UNIQUE (id_time, numero_camisa);
